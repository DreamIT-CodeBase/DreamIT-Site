{
    "hosting": {
      "target": "dream-itcs",
      "public": "out",
      "cleanUrls": true,
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "redirects": [
      {
        "source": "/contact-us/",
        "destination": "/",
        "type": 301
      },
      {
        "source": "/contact-us",
        "destination": "/",
        "type": 301
      },
      {
        "source": "/services",
        "destination": "/services/",
        "type": 301
      },
      {
        "source": "/services/:slug",
        "destination": "/services/:slug/",
        "type": 301
      },
      {
        "source": "/glossary",
        "destination": "/glossary/",
        "type": 301
      },
      {
        "source": "/glossary/:slug",
        "destination": "/glossary/:slug/",
        "type": 301
      },
      {
        "source": "/pay-per-click/",
        "destination": "/services/digital-marketing/",
        "type": 301
      },
      {
        "source": "/pay-per-click",
        "destination": "/services/digital-marketing/",
        "type": 301
      },
      {
        "source": "/data-management/",
        "destination": "/services/cloud-data-management/",
        "type": 301
      },
      {
        "source": "/data-management",
        "destination": "/services/cloud-data-management/",
        "type": 301
      },
      {
        "source": "/search-engine-optimization/",
        "destination": "/services/digital-marketing/",
        "type": 301
      },
      {
        "source": "/search-engine-optimization",
        "destination": "/services/digital-marketing/",
        "type": 301
      },
      {
        "source": "/tableau/",
        "destination": "/services/advanced-analytics/",
        "type": 301
      },
      {
        "source": "/tableau",
        "destination": "/services/advanced-analytics/",
        "type": 301
      },
      {
        "source": "/app-store-optimization/",
        "destination": "/services/digital-marketing/",
        "type": 301
      },
      {
        "source": "/app-store-optimization",
        "destination": "/services/digital-marketing/",
        "type": 301
      },
      {
        "source": "/msbi/",
        "destination": "/services/advanced-analytics/",
        "type": 301
      },
      {
        "source": "/msbi",
        "destination": "/services/advanced-analytics/",
        "type": 301
      },
      {
        "source": "/power-bi/",
        "destination": "/services/advanced-analytics/",
        "type": 301
      },
      {
        "source": "/power-bi",
        "destination": "/services/advanced-analytics/",
        "type": 301
      },
      {
        "regex": "^/(?P<path>(?!.*\\.[^/]+$).+[^/])$",
        "destination": "/:path/",
        "type": 301
      }
    ],
      "headers": [
        {
          "source": "**/*.@(eot|otf|ttf|ttc|woff|font.css)",
          "headers": [
            {
              "key": "Access-Control-Allow-Origin",
              "value": "*"
            }
          ]
        },
        {
          "source": "**/*.@(jpg|jpeg|gif|png|webp)",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "max-age=7200"
            }
          ]
        },
        {
          "source": "404.html",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "max-age=300"
            }
          ]
        }
      ]
    }
  }
