{
  "trailingSlash": "never",
  "routes": [
    {
      "route": "/index.html",
      "redirect": "/",
      "statusCode": 301
    },
    {
      "route": "/contact-us",
      "redirect": "/",
      "statusCode": 301
    },
    {
      "route": "/pay-per-click",
      "redirect": "/services/digital-marketing",
      "statusCode": 301
    },
    {
      "route": "/data-management",
      "redirect": "/services/cloud-data-management",
      "statusCode": 301
    },
    {
      "route": "/search-engine-optimization",
      "redirect": "/services/digital-marketing",
      "statusCode": 301
    },
    {
      "route": "/tableau",
      "redirect": "/services/advanced-analytics",
      "statusCode": 301
    },
    {
      "route": "/app-store-optimization",
      "redirect": "/services/digital-marketing",
      "statusCode": 301
    },
    {
      "route": "/msbi",
      "redirect": "/services/advanced-analytics",
      "statusCode": 301
    },
    {
      "route": "/power-bi",
      "redirect": "/services/advanced-analytics",
      "statusCode": 301
    },
    {
      "route": "/assets/fonts/*.{eot,otf,ttf,ttc,woff}",
      "headers": {
        "Access-Control-Allow-Origin": "*"
      }
    },
    {
      "route": "/assets/*.{jpg,jpeg,gif,png,webp}",
      "headers": {
        "Cache-Control": "max-age=7200"
      }
    },
    {
      "route": "/404.html",
      "headers": {
        "Cache-Control": "max-age=300"
      }
    }
  ]
}
